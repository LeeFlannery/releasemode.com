---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/archivo';
import '@fontsource-variable/newsreader';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SEO } from 'astro-seo';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Release Mode | Engineering-Led Developer Relations',
  description = 'I ship the useful thing first and earn trust before asking for the room. Engineering-led Developer Relations for teams that need a DevRel punch.',
} = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <!-- Set the active theme before first paint (no flash). Order: ?theme=
         param (sticky) → saved choice → default "signal". -->
    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search).get('theme');
          if (p) localStorage.setItem('rm-theme', p);
          var t = p || localStorage.getItem('rm-theme') || 'signal';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'signal');
        }
      })();
    </script>

    <!-- Hide reveal targets before first paint, but only when motion is
         allowed. No-JS / reduced-motion visitors get fully visible content. -->
    <script is:inline>
      if (
        window.matchMedia('(prefers-reduced-motion: no-preference)').matches
      ) {
        document.documentElement.classList.add('reveal-ready');
      }
    </script>

    <SEO title={title} description={description} canonical={canonical} />

    <!-- Animated page transitions, independent of the reveal layer. -->
    <ClientRouter />
  </head>
  <body>
    <slot />

    <!-- Decorative layers for the Broadsheet theme (CSS hides them otherwise):
         paper grain + corner crop marks. -->
    <svg width="0" height="0" style="position: absolute" aria-hidden="true">
      <filter id="rm-grain">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.9"
          numOctaves="2"
          stitchTiles="stitch"></feTurbulence>
        <feColorMatrix type="saturate" values="0"></feColorMatrix>
      </filter>
    </svg>
    <div class="deco-grain" aria-hidden="true"></div>
    <div class="deco-crop" aria-hidden="true"></div>

    <ThemeToggle />
  </body>
</html>
