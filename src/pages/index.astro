---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import Mark from '../assets/brand/mark.svg';

const email = 'lee@releasemode.com';
const schedule = 'https://cal.com/releasemode-lee/officehours';

const offerings = [
  {
    icon: 'tabler:code',
    title: 'Repo + video',
    body: 'A reference implementation your developers can run, plus a walkthrough that teaches the tradeoffs.',
  },
  {
    icon: 'tabler:player-play',
    title: 'A set of shorts',
    body: 'Short, sharp video lessons that build trust and adoption without standing up a content team.',
  },
];

const reasons = [
  {
    icon: 'tabler:rocket',
    title: 'I ship',
    body: 'I write code daily and build the reference implementations myself. Your developers get someone who gets it.',
  },
  {
    icon: 'tabler:arrows-exchange',
    title: 'I translate',
    body: 'I debug with your engineers in the morning and frame DevRel ROI for leadership in the afternoon.',
  },
  {
    icon: 'tabler:school',
    title: 'I teach',
    body: "The goal isn't dependence on me. I leave your team able to keep earning developer trust on their own.",
  },
];

const iconClass =
  'size-11 shrink-0 rounded-full bg-blue p-2.5 text-paper md:size-12 md:p-3';
---

<Layout
  title="Release Mode | Engineering-Led Developer Relations"
  description="I ship the useful thing first and earn trust before asking for the room. Engineering-led Developer Relations for teams that need a DevRel punch."
>
  <!-- Announcement bar -->
  <div class="bg-blue/5 text-ink/70 px-6 py-2 text-center text-sm">
    Questions? Contact
    <a href={`mailto:${email}`} class="text-ink hover:text-blue font-medium"
      >{email}</a
    >.
  </div>

  <!-- Header -->
  <header class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <Mark class="text-ink size-7" />
      Release Mode
    </a>
    <nav class="flex items-center gap-5 text-sm">
      <a href={`mailto:${email}`} class="text-ink/80 hover:text-ink font-medium"
        >Contact</a
      >
      <Button
        href={schedule}
        target="_blank"
        variant="ghost"
        icon={null}
        compact
      >
        Schedule Call
      </Button>
    </nav>
  </header>

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <Mark
      class="pointer-events-none absolute top-1/2 right-0 hidden w-[44rem] translate-x-[20%] -translate-y-1/2 text-white md:block lg:w-[54rem]"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-6 py-16 lg:py-28">
      <div class="animate-fade-in-left max-w-3xl">
        <h1
          class="text-5xl leading-[1.03] font-bold tracking-tight sm:text-6xl lg:text-7xl"
        >
          Engineering&#8209;Led<br />
          <span class="text-blue whitespace-nowrap">Developer Relations</span>
        </h1>
        <p class="text-ink/70 mt-6 max-w-xl text-lg sm:text-xl">
          Digital transformation firms sell the meeting before the artifact.
          Engineering-led DevRel flips that: show the code, explain the
          tradeoffs, publish the docs, build the reference implementation, and
          earn trust before asking for the room.
        </p>
        <div class="mt-10">
          <Button href={schedule} target="_blank">
            Schedule a Strategy Session
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Offerings -->
  <section class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
    <Reveal class="mx-auto mb-14 max-w-3xl text-center">
      <p class="text-blue text-base font-bold tracking-wide uppercase">
        What I Ship
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        What a DevRel punch looks like
      </h2>
      <p class="text-ink/70 mt-4 text-lg">
        Not a strategy deck. The actual artifact your developers use.
      </p>
    </Reveal>
    <Reveal group as="ul" class="grid gap-8 sm:grid-cols-2 md:gap-y-12">
      {
        offerings.map((o) => (
          <li data-reveal class="flex max-w-md flex-row gap-4">
            <Icon name={o.icon} class={iconClass} />
            <div>
              <h3 class="text-xl font-bold md:text-[1.3rem]">{o.title}</h3>
              <p class="text-ink/70 mt-3">{o.body}</p>
            </div>
          </li>
        ))
      }
    </Reveal>
  </section>

  <!-- Positioning statement -->
  <section class="mx-auto max-w-3xl px-6 py-12 text-center">
    <Reveal>
      <p class="text-2xl leading-snug font-semibold text-balance sm:text-3xl">
        Stop selling the meeting. If your best asset is still a strategy deck,
        you're not educating developers. You're selling one.
      </p>
    </Reveal>
  </section>

  <!-- Why -->
  <section class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
    <Reveal class="mx-auto mb-14 max-w-3xl text-center">
      <p class="text-blue text-base font-bold tracking-wide uppercase">
        Why Work with Release Mode
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        I listen to developers and communicate with leadership
      </h2>
      <p class="text-ink/70 mt-4 text-lg">
        Led by Principal Consultant Lee Flannery.
      </p>
    </Reveal>
    <Reveal
      group
      as="ul"
      class="grid gap-8 sm:grid-cols-2 md:gap-y-12 lg:grid-cols-3"
    >
      {
        reasons.map((r) => (
          <li data-reveal class="flex max-w-md flex-row gap-4">
            <Icon name={r.icon} class={iconClass} />
            <div>
              <h3 class="text-xl font-bold md:text-[1.3rem]">{r.title}</h3>
              <p class="text-ink/70 mt-3">{r.body}</p>
            </div>
          </li>
        ))
      }
    </Reveal>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-6 py-12">
    <Reveal
      as="div"
      class="bg-paper/40 mx-auto max-w-3xl rounded-2xl p-8 text-center shadow-xl sm:p-12"
    >
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Ready to talk about solving your adoption problem?
      </h2>
      <p class="text-ink/70 mx-auto mt-4 max-w-xl text-lg">
        Let's talk about how engineering-led DevRel earns trust with your
        developer community.
      </p>
      <div class="mt-8 flex justify-center">
        <Button href={schedule} target="_blank">
          Schedule a Strategy Session
        </Button>
      </div>
    </Reveal>
  </section>

  <!-- Footer -->
  <footer class="mx-auto mt-8 max-w-6xl px-6 py-16">
    <div
      class="border-ink/10 grid gap-10 border-t pt-12 sm:grid-cols-2 lg:grid-cols-4"
    >
      <div class="lg:col-span-2">
        <p class="text-xl font-bold tracking-tight">Release Mode</p>
        <p class="text-ink/70 mt-3 max-w-xs">
          Developer Relations Engineering. I show the code. I earn trust before
          asking for the room.
        </p>
      </div>
      <div>
        <p class="text-ink text-sm font-bold tracking-wide uppercase">
          Company
        </p>
        <ul class="text-ink/70 mt-4 space-y-3">
          <li>
            <a href={`mailto:${email}`} class="hover:text-blue">Contact</a>
          </li>
        </ul>
      </div>
      <div>
        <p class="text-ink text-sm font-bold tracking-wide uppercase">
          Get Started
        </p>
        <ul class="text-ink/70 mt-4 space-y-3">
          <li>
            <a
              href={schedule}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue">Schedule Call</a
            >
          </li>
          <li>
            <a href={`mailto:${email}`} class="hover:text-blue">Email Lee</a>
          </li>
          <li>
            <a
              href="https://leeflannery.com"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue">About Founder Lee Flannery</a
            >
          </li>
        </ul>
      </div>
    </div>
    <p class="text-ink/50 mt-12 text-sm">
      © 2026 Release Mode. Engineering-Led Developer Relations.
    </p>
  </footer>
</Layout>
