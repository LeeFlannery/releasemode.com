---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
import Button from '../components/Button.astro';
import ProofSection from '../components/ProofSection.astro';
import { Icon } from 'astro-icon/components';
import Mark from '../assets/brand/mark.svg';

const email = 'lee@releasemode.com';
const schedule = 'https://cal.com/releasemode-lee/officehours';

const offerings = [
  {
    icon: 'tabler:code',
    title: 'Reference repo + video',
    body: 'A working implementation your team clones and runs, with a walkthrough of the decisions and tradeoffs behind it.',
  },
  {
    icon: 'tabler:player-play',
    title: 'A set of shorts',
    body: 'Short, sharp video lessons that build trust and adoption without standing up a content team.',
  },
];

const reasons = [
  {
    icon: 'tabler:rocket',
    title: 'I ship',
    body: 'I write code daily and build the reference implementations myself, so I meet your developers as a peer who shares their constraints.',
  },
  {
    icon: 'tabler:arrows-exchange',
    title: 'I translate',
    body: 'I debug with your engineers in the morning and frame DevRel ROI for leadership in the afternoon.',
  },
  {
    icon: 'tabler:school',
    title: 'I teach',
    body: "The goal isn't dependence on me. I leave your team able to keep earning developer trust on their own.",
  },
];

const iconClass =
  'size-11 shrink-0 rounded-full bg-blue p-2.5 text-paper md:size-12 md:p-3';
---

<Layout
  title="Release Mode | Engineering-Led Developer Relations"
  description="I ship the useful thing first and earn trust before asking for the room. Engineering-led Developer Relations for teams that need a DevRel punch."
>
  <!-- Announcement bar -->
  <div
    class="bg-blue/5 text-ink/70 px-6 py-2 text-center text-sm sm:px-8 lg:px-12"
  >
    Questions? Contact
    <a href={`mailto:${email}`} class="text-ink hover:text-blue font-medium"
      >{email}</a
    >.
  </div>

  <!-- Top band (yellow): header + hero -->
  <div class="bg-brand">
    <!-- Header -->
    <header
      class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 sm:px-8 lg:px-12"
    >
      <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
        <Mark class="text-ink size-7" />
        Release Mode
      </a>
      <nav class="flex items-center gap-5 text-sm">
        <a
          href={`mailto:${email}`}
          class="text-ink/80 hover:text-ink font-medium">Contact</a
        >
        <Button
          href={schedule}
          target="_blank"
          variant="ghost"
          icon={null}
          compact
        >
          Let's talk
        </Button>
      </nav>
    </header>

    <!-- Hero -->
    <section
      class="relative mx-auto grid max-w-7xl items-center gap-10 overflow-hidden px-6 pt-8 pb-16 sm:px-8 lg:min-h-[78vh] lg:grid-cols-2 lg:gap-12 lg:px-12 lg:pt-0 lg:pb-20"
    >
      <!-- Small screens: the mark sits behind the text (z-axis background). -->
      <Mark
        class="pointer-events-none absolute top-1/2 right-0 w-[26rem] max-w-[85%] translate-x-[12%] -translate-y-1/2 text-white/80 lg:hidden"
        aria-hidden="true"
      />
      <div class="animate-fade-in-left relative z-10">
        <h1
          class="text-5xl leading-[1.03] font-bold tracking-tight sm:text-6xl"
        >
          Engineering&#8209;Led<br />
          <span class="text-blue whitespace-nowrap">Developer Relations</span>
        </h1>
        <p class="text-ink/70 mt-6 max-w-xl text-lg sm:text-xl">
          Digital transformation firms sell the meeting before the artifact.
          Engineering-led DevRel flips that: show the code, explain the
          tradeoffs, publish the docs, build the reference implementation, and
          earn trust before asking for the room.
        </p>
        <div class="mt-10">
          <Button href={schedule} target="_blank">Let's talk</Button>
          <p class="text-ink/60 mt-3 text-sm">30 minutes. No deck.</p>
        </div>
      </div>
      <!-- Desktop: the mark gets its own column beside the text. -->
      <div class="animate-fade-in-right hidden lg:flex lg:justify-end">
        <Mark class="w-full text-white" aria-label="Release Mode" />
      </div>
    </section>
  </div>

  <!-- Offerings -->
  <section class="mx-auto max-w-5xl px-6 py-20 sm:px-8 sm:py-28 lg:px-12">
    <Reveal class="mx-auto mb-14 max-w-3xl text-center">
      <p class="text-blue text-base font-bold tracking-wide uppercase">
        What I Ship
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        You get the artifact, not a deck
      </h2>
      <p class="text-ink/70 mt-4 text-lg">
        Every engagement ends in something your developers can clone, read, or
        watch. Not a slide about it.
      </p>
    </Reveal>
    <Reveal group as="ul" class="grid gap-8 sm:grid-cols-2 md:gap-y-12">
      {
        offerings.map((o) => (
          <li
            data-reveal
            class="card-hover bg-brand flex flex-row gap-4 rounded-2xl p-6 md:p-8"
          >
            <Icon name={o.icon} class={iconClass} />
            <div>
              <h3 class="text-xl font-bold md:text-[1.3rem]">{o.title}</h3>
              <p class="text-ink/70 mt-3">{o.body}</p>
            </div>
          </li>
        ))
      }
    </Reveal>
  </section>

  <!-- Positioning statement -->
  <section class="mx-auto max-w-3xl px-6 py-12 text-center sm:px-8 lg:px-12">
    <Reveal>
      <p class="text-2xl leading-snug font-semibold text-balance sm:text-3xl">
        Make the useful thing first. Developers trust what they can run, not
        what they're shown. Let the work earn the room.
      </p>
    </Reveal>
  </section>

  <!-- Why -->
  <section class="mx-auto max-w-5xl px-6 py-20 sm:px-8 sm:py-28 lg:px-12">
    <Reveal class="mx-auto mb-14 max-w-3xl text-center">
      <p class="text-blue text-base font-bold tracking-wide uppercase">
        Why Work with Release Mode
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        I listen to developers and communicate with leadership
      </h2>
      <p class="text-ink/70 mt-4 text-lg">
        Led by Principal Consultant Lee Flannery.
      </p>
    </Reveal>
    <Reveal
      group
      as="ul"
      class="grid gap-8 sm:grid-cols-2 md:gap-y-12 lg:grid-cols-3"
    >
      {
        reasons.map((r) => (
          <li
            data-reveal
            class="card-hover bg-brand flex flex-row gap-4 rounded-2xl p-6 md:p-8"
          >
            <Icon name={r.icon} class={iconClass} />
            <div>
              <h3 class="text-xl font-bold md:text-[1.3rem]">{r.title}</h3>
              <p class="text-ink/70 mt-3">{r.body}</p>
            </div>
          </li>
        ))
      }
    </Reveal>
  </section>

  <!-- Proof -->
  <ProofSection />

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-6 py-12 sm:px-8 lg:px-12">
    <Reveal
      as="div"
      class="bg-brand mx-auto max-w-3xl rounded-3xl p-8 text-center shadow-xl sm:p-12"
    >
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Ready to talk about solving your adoption problem?
      </h2>
      <p class="text-ink/70 mx-auto mt-4 max-w-xl text-lg">
        Tell me where adoption is stuck, and I'll show you how engineering-led
        DevRel earns your developers' trust.
      </p>
      <div class="mt-8 flex flex-col items-center gap-3">
        <Button href={schedule} target="_blank">Let's talk</Button>
        <p class="text-ink/70 text-sm">30 minutes. No deck.</p>
      </div>
    </Reveal>
  </section>

  <!-- Footer -->
  <footer class="mx-auto mt-8 max-w-6xl px-6 py-16 sm:px-8 lg:px-12">
    <div
      class="border-ink/10 grid gap-10 border-t pt-12 sm:grid-cols-2 lg:grid-cols-4"
    >
      <div class="lg:col-span-2">
        <p class="text-xl font-bold tracking-tight">Release Mode</p>
        <p class="text-ink/70 mt-3 max-w-xs">
          Developer Relations Engineering. I show the code. I earn trust before
          asking for the room.
        </p>
      </div>
      <div>
        <p class="text-ink text-sm font-bold tracking-wide uppercase">
          Company
        </p>
        <ul class="text-ink/70 mt-4 space-y-3">
          <li>
            <a href={`mailto:${email}`} class="hover:text-blue">Contact</a>
          </li>
          <li>
            <a
              href="https://github.com/leeflannery"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue inline-flex items-center gap-1.5"
            >
              <Icon name="tabler:brand-github" class="size-4" />
              GitHub
            </a>
          </li>
        </ul>
      </div>
      <div>
        <p class="text-ink text-sm font-bold tracking-wide uppercase">
          Get Started
        </p>
        <ul class="text-ink/70 mt-4 space-y-3">
          <li>
            <a
              href={schedule}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue">Schedule Call</a
            >
          </li>
          <li>
            <a href={`mailto:${email}`} class="hover:text-blue">Email Lee</a>
          </li>
          <li>
            <a
              href="https://leeflannery.com"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-blue">About Founder Lee Flannery</a
            >
          </li>
        </ul>
      </div>
    </div>
    <p class="text-ink/50 mt-12 text-sm">
      © 2026 Release Mode. Engineering-Led Developer Relations.
    </p>
  </footer>
</Layout>
