---
/*
 * SCRATCH / DESIGN LAB — not linked from the site, not part of the theme system.
 * An art-directed "graphic artist take" on the Press editorial theme:
 * "Release Broadsheet" — Swiss editorial × technical blueprint. Warm paper,
 * heavy Archivo masthead, Newsreader serif, JetBrains-mono spec annotations,
 * crop marks, baseline grid, paper grain. Release Blue + yellow only.
 *
 * View at /lab/press. Self-contained: own fonts + styles, ignores global theme.
 */
import '@fontsource-variable/archivo';
import '@fontsource-variable/newsreader';
import '@fontsource-variable/jetbrains-mono';
import Mark from '../../assets/brand/mark.svg';

const models = [
  ['DevRel / DX Engineering', 'from $125/hr', 'Embedded delivery on your developer surface.'],
  ['Lead / Principal DevRel', 'from $150/hr', 'Own the paved road end to end.'],
  ['Forward Deployed Engineering', 'from $140/hr', "Embedded in a customer's stack."],
  ['Fractional CTO / Advisory', 'from $9K/mo', 'Direction, architecture, team leverage.'],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Release Mode · Broadsheet</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Paper grain (SVG noise), reused as a fixed overlay. -->
    <svg width="0" height="0" style="position:absolute">
      <filter id="grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
    </svg>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <div class="crop" aria-hidden="true"></div>

    <main class="sheet">
      <!-- Masthead bar -->
      <header class="bar">
        <div class="wordmark">Release&nbsp;Mode<span class="dot">.</span></div>
        <div class="status">
          <span class="led"></span>BUILD: RELEASE
        </div>
      </header>
      <div class="rule rule--heavy"></div>

      <!-- Cover -->
      <section class="cover">
        <div class="masthead">
          <div class="kicker"><span class="idx">01</span>&nbsp;/&nbsp;04 &nbsp;—&nbsp; ENGINEERING-LED DEVELOPER RELATIONS</div>
          <h1 class="display">
            <span class="ln a">Engineering</span>
            <span class="ln b">Led<span class="amp">&amp;</span>Shipped</span>
            <span class="ln c"><mark class="hl">Developer</mark> Relations</span>
          </h1>
        </div>

        <aside class="col">
          <p class="lede">
            Digital transformation firms sell the meeting before the artifact.
            Engineering-led DevRel flips it: show the code, explain the
            tradeoffs, publish the docs, build the reference implementation —
            and earn trust before asking for the room.
          </p>
          <a class="cta" href="#">
            Let's scope it <span class="arr">→</span>
          </a>
          <p class="meta">30 MIN · NO DECK · MICHIGAN · REMOTE, US TZ</p>
        </aside>

        <!-- Blueprint mark, bleeding off the right edge -->
        <div class="blueprint" aria-hidden="true">
          <Mark class="bp-mark" />
          <span class="bp-tag">FIG. 1 — RELEASE TOPOLOGY</span>
        </div>
      </section>

      <div class="rule"></div>

      <!-- Engagement models — editorial ledger -->
      <section class="ledger">
        <div class="kicker"><span class="idx">02</span>&nbsp;/&nbsp;04 &nbsp;—&nbsp; <span class="blue">// WAYS TO WORK TOGETHER</span></div>
        <h2 class="display sub">Engagement<br />models</h2>
        <table class="rates">
          <thead>
            <tr><th>Model</th><th class="r">Rate</th></tr>
          </thead>
          <tbody>
            {models.map(([name, rate, note]) => (
              <tr>
                <td>
                  <span class="tier">{name}</span>
                  <span class="note">{note}</span>
                </td>
                <td class="r num">{rate}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <footer class="foot">
        <span>RELEASE MODE LLC</span>
        <span class="blue">●</span>
        <span>EFFECTIVE 2026</span>
        <span class="blue">●</span>
        <span>SUBJECT TO SCOPE</span>
        <span class="spacer"></span>
        <span class="num">v0.0.1</span>
      </footer>
    </main>

    <style>
      :root {
        --paper: #fbfaf6;
        --paper-2: #f1eee2;
        --ink: #16140f;
        --ink-soft: #5d564a;
        --blue: #0070f3;
        --yellow: #fbcc4c;
        --hair: #d9d3c4;
        --display: 'Archivo Variable', system-ui, sans-serif;
        --serif: 'Newsreader Variable', Georgia, serif;
        --mono: 'JetBrains Mono Variable', ui-monospace, monospace;
      }

      * { box-sizing: border-box; }
      html { background: var(--paper); }
      body {
        margin: 0;
        color: var(--ink);
        font-family: var(--serif);
        background:
          /* faint baseline grid */
          repeating-linear-gradient(
            to bottom,
            transparent 0 47px,
            color-mix(in srgb, var(--hair) 55%, transparent) 47px 48px
          ),
          var(--paper);
        -webkit-font-smoothing: antialiased;
      }

      /* Paper grain overlay */
      .grain {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        opacity: 0.05;
        mix-blend-mode: multiply;
        filter: url(#grain);
      }

      /* Crop marks at the four corners of the viewport */
      .crop { position: fixed; inset: 18px; pointer-events: none; z-index: 50; }
      .crop::before,
      .crop::after {
        content: '';
        position: absolute;
        width: 14px; height: 14px;
        border: 0 solid var(--ink);
      }
      .crop::before { top: 0; left: 0; border-top-width: 1.5px; border-left-width: 1.5px; }
      .crop::after { bottom: 0; right: 0; border-bottom-width: 1.5px; border-right-width: 1.5px; }

      .sheet {
        max-width: 1180px;
        margin: 0 auto;
        padding: 40px 44px 28px;
      }

      /* Masthead bar */
      .bar {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
      }
      .wordmark {
        font-family: var(--display);
        font-weight: 800;
        font-stretch: 115%;
        text-transform: uppercase;
        letter-spacing: -0.01em;
        font-size: clamp(18px, 2.2vw, 26px);
      }
      .dot { color: var(--blue); }
      .status {
        font-family: var(--mono);
        font-weight: 700;
        font-size: 11px;
        letter-spacing: 0.14em;
        color: var(--ink);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .led {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--blue);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--blue) 22%, transparent);
        animation: pulse 2.4s ease-in-out infinite;
      }
      @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }

      .rule { height: 1.5px; background: var(--hair); margin: 14px 0; }
      .rule--heavy { height: 3px; background: var(--ink); margin: 12px 0 0; }

      /* Cover grid */
      .cover {
        position: relative;
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 40px;
        padding: 30px 0 44px;
        overflow: hidden;
      }
      .masthead, .col { position: relative; z-index: 1; }
      .kicker {
        font-family: var(--mono);
        font-weight: 700;
        font-size: 11.5px;
        letter-spacing: 0.16em;
        color: var(--ink-soft);
        text-transform: uppercase;
      }
      .idx { color: var(--blue); }
      .blue { color: var(--blue); }

      .display {
        font-family: var(--display);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 0.9;
        margin: 18px 0 0;
        text-transform: none;
      }
      h1.display { font-size: clamp(52px, 9vw, 126px); }
      .ln { display: block; }
      .ln.b { color: var(--ink); }
      .amp {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        color: var(--blue);
        padding: 0 0.12em;
        letter-spacing: 0;
      }
      .ln.c { font-size: 0.82em; }
      mark.hl {
        background: linear-gradient(transparent 12%, var(--yellow) 12% 86%, transparent 86%);
        color: var(--ink);
        padding-inline: 0.06em;
        -webkit-box-decoration-break: clone;
        box-decoration-break: clone;
      }

      .col { align-self: end; padding-bottom: 6px; }
      .lede {
        font-size: clamp(17px, 1.5vw, 20px);
        line-height: 1.5;
        color: #2a2720;
        margin: 0 0 22px;
        max-width: 34ch;
      }
      .cta {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: var(--blue);
        color: var(--paper);
        text-decoration: none;
        font-family: var(--mono);
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 13px 20px;
        border-radius: 3px;
        transition: transform 0.18s ease, background 0.18s ease;
      }
      .cta:hover { transform: translateY(-2px); background: #005fd0; }
      .cta .arr { transition: transform 0.18s ease; }
      .cta:hover .arr { transform: translateX(4px); }
      .meta {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        color: var(--blue);
        margin: 16px 0 0;
      }

      /* Blueprint mark — technical diagram, lower-right of the cover */
      .blueprint {
        position: absolute;
        right: 8px;
        bottom: 22px;
        width: 270px;
        z-index: 0;
        pointer-events: none;
      }
      .bp-mark {
        width: 100%;
        height: auto;
        color: color-mix(in srgb, var(--blue) 34%, transparent);
      }
      .bp-tag {
        position: absolute;
        left: 2px;
        bottom: -16px;
        font-family: var(--mono);
        font-size: 9.5px;
        letter-spacing: 0.14em;
        color: var(--blue);
        white-space: nowrap;
      }

      /* Ledger */
      .ledger { padding: 26px 0 10px; }
      .display.sub { font-size: clamp(34px, 5vw, 60px); margin: 10px 0 22px; }
      .rates { width: 100%; border-collapse: collapse; }
      .rates th {
        font-family: var(--mono);
        font-weight: 700;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-soft);
        text-align: left;
        padding: 0 0 10px;
        border-bottom: 2px solid var(--ink);
      }
      .rates th.r, .rates td.r { text-align: right; }
      .rates td { padding: 17px 0; border-bottom: 1px solid var(--hair); vertical-align: baseline; }
      .tier {
        display: block;
        font-family: var(--display);
        font-weight: 700;
        font-size: 19px;
        letter-spacing: -0.01em;
      }
      .note { display: block; color: var(--ink-soft); font-size: 15px; margin-top: 3px; }
      .num {
        font-family: var(--mono);
        font-weight: 500;
        color: var(--blue);
        white-space: nowrap;
        font-size: 15px;
      }

      .foot {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: 26px;
        padding-top: 14px;
        border-top: 1px solid var(--hair);
        font-family: var(--mono);
        font-size: 10.5px;
        letter-spacing: 0.12em;
        color: var(--ink-soft);
        text-transform: uppercase;
      }
      .foot .blue { font-size: 8px; }
      .foot .spacer, .foot .spacer { flex: 1; }
      .foot .num { margin-left: auto; }

      /* Staggered entrance */
      @media (prefers-reduced-motion: no-preference) {
        .ln, .col > *, .kicker, .status, .wordmark {
          animation: rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both;
        }
        .wordmark { animation-delay: 0.02s; }
        .status { animation-delay: 0.06s; }
        .ln.a { animation-delay: 0.12s; }
        .ln.b { animation-delay: 0.2s; }
        .ln.c { animation-delay: 0.28s; }
        .col > * { animation-delay: 0.4s; }
        .blueprint { animation: fade 1.1s ease 0.5s both; }
      }
      @keyframes rise { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
      @keyframes fade { from { opacity: 0; } to { opacity: 1; } }

      @media (max-width: 860px) {
        .cover { grid-template-columns: 1fr; gap: 24px; }
        .blueprint { display: none; }
        .col { align-self: start; }
      }
    </style>
  </body>
</html>
